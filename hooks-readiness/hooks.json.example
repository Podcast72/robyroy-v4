{
  "notice": "PROPOSAL ONLY / NOT ACTIVE / DO NOT COPY WITHOUT REVIEW / REQUIRES MANUAL TRUST REVIEW / DO NOT ENABLE DURING AIOS TESTING",
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python3 /path/to/robyroy-v4/hooks-readiness/scripts/v4_user_prompt_submit_hook.py"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "type": "command",
        "command": "python3 /path/to/robyroy-v4/hooks-readiness/scripts/v4_pre_tool_guard_hook.py"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 /path/to/robyroy-v4/hooks-readiness/scripts/v4_stop_continue_hook.py"
      }
    ]
  }
}
